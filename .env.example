# === Future with Serdar — Ortam Değişkenleri ===
# Bu dosyayı .env olarak kopyalayın ve doldurun: cp .env.example .env

# --- Faz 1 (zorunlu) ---
ANTHROPIC_API_KEY=

# --- Faz 3: Podcast barındırma — Cloudflare R2 (S3 uyumlu) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=future-with-serdar
# Bucket'ın herkese açık (r2.dev) adresi veya özel alan adın:
R2_PUBLIC_BASE_URL=

# --- Opsiyonel: Supabase (sadece DB loglama; yoksa atlanır) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Faz 2+ (ses/montaj) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Faz 3+ (yayın) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Marka / yayın bilgileri ---
PODCAST_TITLE=Future with Serdar
PODCAST_AUTHOR=Serdar
PODCAST_BASE_URL=
